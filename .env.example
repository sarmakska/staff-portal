# ============================================================
# StaffPortal — Environment Variables
# Copy this file to .env.local and fill in your own values
# NEVER commit .env.local to version control
# ============================================================

# ── Supabase ──────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only — NEVER expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Resend (Email) ────────────────────────────────────────
# Get from: resend.com → API Keys
# Your sending domain must be verified in Resend
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── App Config ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-staffportal-url.com

# ── Email Destinations ────────────────────────────────────
# Where system notifications get sent
WFH_NOTIFY_EMAIL=admin@yourcompany.com
ACCOUNTS_NOTIFY_EMAIL=accounts@yourcompany.com

# Auth: only emails ending with this domain can sign up
# Set to empty string "" to allow any email domain
NEXT_AUTH_DOMAIN=@yourcompany.com

# Admin email — gets admin role automatically on first login
NEXT_PUBLIC_ADMIN_EMAIL=admin@yourcompany.com

# ── Cron Authentication ───────────────────────────────────
# Secret token to authenticate Vercel Cron job calls
# Set the same value in Vercel Dashboard → Settings → Environment Variables
CRON_SECRET=your-random-secret-string

# ── AI Receipt OCR (Optional) ─────────────────────────────
# Required for AI-powered receipt scanning in the Expenses module
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Google Gemini (Alternative OCR) ──────────────────────
# Optional alternative to Anthropic for receipt scanning
# Get from: ai.google.dev
GOOGLE_GEMINI_API_KEY=your-gemini-api-key
