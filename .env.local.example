# ============================================================
# StaffPortal — Environment Variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to version control
# ============================================================

# ── Supabase ──────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — ONLY used on server-side/Edge Functions. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Resend ────────────────────────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key

# The "from" address for all system emails (must be a verified domain in Resend)
RESEND_FROM_EMAIL=noreply@yournotifications.com

# ── App Config ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-staffportal-url.com

# The email address that receives WFH notifications
WFH_NOTIFY_EMAIL=admin@yourcompany.com

# The email address that receives leave approval notifications
ACCOUNTS_NOTIFY_EMAIL=accounts@yourcompany.com

# The email address that receives attendance correction requests
RECEPTION_NOTIFY_EMAIL=reception@yourcompany.com

# Internal admin email — auto-assigned admin role on signup
ADMIN_SEED_EMAIL=admin@yourcompany.com

# Auth domain — only emails ending with this can sign up
NEXT_AUTH_DOMAIN=@yourcompany.com

# Admin email — auto-assigned admin + accounts roles on login
NEXT_PUBLIC_ADMIN_EMAIL=admin@yourcompany.com
